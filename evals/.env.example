# Required: Anthropic API key — used as the DeepEval judge model (AnthropicModel)
# and as the chatbot-under-test LLM in model_callback.
ANTHROPIC_API_KEY=

# Required: Utah Legislature API key — passed to the MCP server at startup.
# Obtain from https://le.utah.gov/api
UTAH_LEGISLATURE_API_KEY=

# Required: UGRC API key — used by the MCP server for address-to-district geocoding.
# Obtain from https://developer.utah.gov
UGRC_API_KEY=

# Optional: OpenAI API key — required only when using the OpenAI provider for
# the chatbot-under-test (pluggable LLM provider story). Not needed for Claude runs.
OPENAI_API_KEY=

# Optional: Confident AI API key — enables DeepEval cloud dashboard for eval run
# tracking, metric history, and regression comparisons.
# Obtain from https://app.confident-ai.com
CONFIDENT_API_KEY=
